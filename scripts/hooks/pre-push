#!/bin/bash
# Pre-push hook: blocks direct pushes to protected branches.
# Install via: ./scripts/setup-hooks.sh

PROTECTED_BRANCHES="main develop"
CURRENT_BRANCH=$(git symbolic-ref HEAD 2>/dev/null | sed 's|refs/heads/||')

for branch in $PROTECTED_BRANCHES; do
  if [ "$CURRENT_BRANCH" = "$branch" ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════╗"
    echo "║  PUSH BLOCKED: direct push to '$branch' is disabled  ║"
    echo "║                                                        ║"
    echo "║  Use a feature branch and open a pull request instead. ║"
    echo "║                                                        ║"
    echo "║  To bypass (emergency only):                           ║"
    echo "║    git push --no-verify origin $branch                 ║"
    echo "╚══════════════════════════════════════════════════════╝"
    echo ""
    exit 1
  fi
done

exit 0
